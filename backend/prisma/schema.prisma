generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  user
  hotelOwner
}

model User {
  id                   String   @id @default(uuid())
  name                 String
  email                String   @unique
  password             String
  image                String?
  role                 Role     @default(user)
  recentSearchedCities String[]

  hotels                 Hotel[]

  createdAt DateTime @default(now())
}

model Hotel {
  id   String @id @default(uuid())
  name String
  address String
  contact String
  city String

  ownerId   String
  owner     User     @relation(fields: [ownerId], references: [id])

  rooms     Room[]

  createdAt DateTime @default(now())
}

model Room {
  id String @id @default(uuid())
  roomType String
  pricePerNight Int
  amenities      String[]  
  images         String[]
  isAvailable Boolean


  hotelId String
  hotel Hotel @relation(fields: [hotelId], references: [id])

  createdAt DateTime @default(now())

}