generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  user
  hotelOwner
}

enum Status {
  pending
  confirmed
  cancelled
}

model User {
  id                   String   @id @default(uuid())
  name                 String
  email                String   @unique
  password             String
  image                String?
  role                 Role     @default(user)
  recentSearchedCities String[]

  hotels                 Hotel[]
  bookings Booking[]

  createdAt DateTime @default(now())
}

model Hotel {
  id   String @id @default(uuid())
  name String
  address String
  contact String
  city String

  ownerId   String
  owner     User     @relation(fields: [ownerId], references: [id])

  rooms     Room[]
  bookings Booking[]

  createdAt DateTime @default(now())
}

model Room {
  id String @id @default(uuid())
  roomType String
  pricePerNight Int
  amenities      String[]  
  images         String[]
  isAvailable Boolean
  createdAt DateTime @default(now())


  hotelId String
  hotel Hotel @relation(fields: [hotelId], references: [id])

  bookings       Booking[]


}

model Booking {
  id String @id @default(uuid())
  userId String
  roomId String
  hotelId String
  checkInDate DateTime
  checkOutDate DateTime
  totalPrice Int
  guests Int
  status Status @default(pending)
  paymentMethod String @default("Pay at Hotel")
  isPaid Boolean @default(false)
  createdAt DateTime @default(now())
  

  user User @relation(fields: [userId], references: [id])
  room Room @relation(fields: [roomId], references: [id])
  hotel Hotel @relation(fields: [hotelId], references: [id])


}